# Line endings
* text=auto eol=lf

# Web files
*.js   text eol=lf
*.ts   text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md   text eol=lf

# Config / scripts
*.sh   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binary files
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary

*.wasm binary
*.zip  binary
*.mp4  binary
*.mp3  binary

# Diff improvements
*.json diff=json
*.md   diff=markdown
